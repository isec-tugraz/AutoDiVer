\newcommand{\giftaddkey}{
  \ifsmallgift
    % GIFT-64: n/2-bit round key U || V with U added to b_{4i+1} and V to b_{4i}
    \foreach \bit[evaluate=\bit as \ubit using {int(mod(4*\bit+1,64))},
                  evaluate=\bit as \vbit using {int(mod(4*\bit+0,64))}] in {0,...,15} {
      \draw (b\ubit|-here) coordinate[xor] (uk\bit);
      \draw (b\vbit|-here) coordinate[xor] (vk\bit);
      %\draw[->] (bh\ubit) -- (uk\bit);
      %\draw[->] (bh\vbit) -- (vk\bit);
      %\draw (uk\bit.south) coordinate (bh\ubit);
      %\draw (vk\bit.south) coordinate (bh\vbit);
    }
    \foreach \bit in {63,23,19,15,11,7,3} {
      \draw (b\bit|-here) coordinate[xor,gray] (ck\bit);
    }
  \else
    % GIFT-128 n/2-bit round key U || V with U added to b_{4i+1} and V to b_{4i}
    \foreach \bit[evaluate=\bit as \ubit using {int(mod(4*\bit+2,128))},
                  evaluate=\bit as \vbit using {int(mod(4*\bit+1,128))}] in {0,...,31} {
      \draw (b\ubit|-here) coordinate[xor] (uk\bit);
      \draw (b\vbit|-here) coordinate[xor] (vk\bit);
      %\draw[->] (bh\ubit) -- (uk\bit);
      %\draw[->] (bh\vbit) -- (vk\bit);
      %\draw (uk\bit.south) coordinate (bh\ubit);
      %\draw (vk\bit.south) coordinate (bh\vbit);
    }
    \foreach \bit in {127,23,19,15,11,7,3} {
      \draw (bh\bit|-here) coordinate[xor,gray] (ck\bit);
    }
  \fi
  \spnstep[0.06]
}

