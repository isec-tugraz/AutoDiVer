      \draw (\zzz,0)  node[above] {$\Xs{\varidx}{\zzz}$}  ++( .25,0) coordinate (t\zzz);
      \draw (\zz,-3)  node[below] {$\Cs{#1}{\zz}$}  ++(-.25,0) coordinate (b\zz);
      \draw (\zzz,-3) node[below] {$\Cs{#1}{\zzz}$} ++( .25,0) coordinate (b\zzz);
