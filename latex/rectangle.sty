\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{rectangle}[2024/09/02 Utils for illustrating the RECTANGLE cipher]

\RequirePackage{xspace}
\RequirePackage{tikz}
\usetikzlibrary{calc,positioning} %,cipher}

\newif\ifrectanglelabelrows\rectanglelabelrowstrue

%%% GENERAL CRYPTO UTILS %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\providecommand{\cipher}[1]{\textsf{#1}}

\providecommand{\SC}{\cipher{SC}\xspace}
\providecommand{\SR}{\cipher{SR}\xspace}
\providecommand{\AK}{\cipher{AK}\xspace}

\providecommand{\SubColumn}{\cipher{SubColumn}\xspace}
\providecommand{\ShiftRow}{\cipher{ShiftRow}\xspace}
\providecommand{\AddRoundKey}{\cipher{AddRoundKey}\xspace}

\providecommand{\RECTANGLE}[1][]{\if\relax\detokenize{#1}\relax\cipher{RECTANGLE}\else\mbox{\cipher{RECTANGLE}-#1}\fi\xspace}

%%% SPEEDY TIKZ STYLES %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\tikzset{rectangle/.style={xscale=-0.2,yscale=-0.2}}

%%% SPEEDY-STATE TIKZ MACROS %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\newcommand{\RectangleStateDraw}{
  \foreach \i in {1,2,...,15} \draw[black!25] (\i,0) -- (\i,4);
  \foreach \j in {1,...,3} \draw (0,\j) -- (16,\j);
  \draw[thick] (0,0) rectangle (16,4);
  \foreach \j in {0,...,3} \draw (0,\j+0.5) node[right,inner sep=1pt,font=\tiny] {$\j$};
  \ifrectanglelabelrows
  \foreach \i in {0,...,15} \draw (\i+0.5,0) node[above,inner sep=1pt,font=\tiny] {$\i$};
  \fi
}
\newcommand{\RectangleStateBit}[3][]{
  \fill[#1] (#3,#2) rectangle ++(1,1);
}
\newcommand{\RectangleWriteBit}[3][]{
  \draw (#3,#2) ++(.5,1) node[above, inner sep=0pt, font=\tiny] {#1};
}
\newcommand{\RectangleStep}[2][]{\tikz[rectangle]{\draw[->] (0,4) (0,2) -- node[above=3pt,font=\small,align=center,inner sep=0pt] {#2} node[below=3pt,font=\small,inner sep=0pt] {#1} +(-2,0);}}
\newcommand{\RectangleInvStep}[2][]{\tikz[rectangle]{\draw[<-] (0,32) (0,16) -- node[above=3pt,font=\small,align=center,inner sep=0pt] {#2} node[below=3pt,font=\small,inner sep=0pt] {#1} +(-2,0);}}

