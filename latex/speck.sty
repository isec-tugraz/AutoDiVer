\newcommand{\SimonHalfState}[1]{%
  \tikz[simonstateopts]{
    \foreach \s in {0,...,\lastB} {
      \draw (\s+.5,-.5) coordinate (s\s);
      \draw (\lastB-\s+.5,-.5) coordinate (b\s); % big endian, b0 = LSB = rightmost
    }
    \draw (8,-.5) coordinate (label);
    #1
    \draw (0,0) rectangle (\sizeB,-1);
    \foreach \x in {1,...,\lastB} {
      \draw[raster] (\x,0) -- ++(0,-1);
    }
  }%
}


